# StatMind — environment variable reference
# Copy to .env.prod (server) or .env (local) and fill in real values.
# NEVER commit the filled-in file. Only this .example is tracked.

ENVIRONMENT=production
PORT=8000
APP_URL=https://statmind.tech

# CORS: comma-separated origins. In prod, unset defaults to the site origins (never "*").
ALLOWED_ORIGINS=https://statmind.tech,https://www.statmind.tech

DATABASE_URL=sqlite:////app/data/statmind.db

# Secrets — generate strong values; never reuse:
#   JWT_SECRET:   openssl rand -hex 32
#   ADMIN_SECRET: openssl rand -hex 16
JWT_SECRET=change-me-openssl-rand-hex-32
ADMIN_SECRET=change-me-openssl-rand-hex-16

# Email (Resend): https://resend.com/api-keys
RESEND_API_KEY=change-me

MAX_UPLOAD_MB=25
REPORT_CACHE_TTL=3600
REPORT_CACHE_MAX=200
